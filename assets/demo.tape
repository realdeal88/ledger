# Regenerate the README gif:  vhs assets/demo.tape   (run from the repo root)
Output assets/demo.gif

Set Shell bash
Set FontSize 21
Set Width 1180
Set Height 720
Set Padding 30
Set Theme "Catppuccin Mocha"
Set TypingSpeed 55ms

Hide
Type `export PS1=$'\033[38;2;79;182;163m❯\033[0m '`
Enter
Type "alias claude='bash assets/demo.sh'"
Enter
Type "clear"
Enter
Show

Sleep 700ms
Type "claude"
Sleep 700ms
Enter
Sleep 6s
